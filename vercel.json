{
  "version": 2,
  "builds": [
    {
      "src": "wsgi.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/sw.js",
      "dest": "/sw.js",
      "headers": {
        "Service-Worker-Allowed": "/",
        "Cache-Control": "no-cache, no-store, must-revalidate"
      }
    },
    {
      "src": "/(.*)",
      "dest": "/wsgi.py"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/push-reminders",
      "schedule": "*/5 * * * 0-4"
    },
    {
      "path": "/api/cron/daily",
      "schedule": "0 18 * * 0-4"
    }
  ]
}