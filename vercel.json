{
  "version": 2,
  "functions": {
    "api/index.py": {
      "maxDuration": 30,
      "includeFiles": "requirements.txt,templates/**,static/**,app/**,core/**,config.py"
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.py"
    }
  ],
  "env": {
    "FLASK_ENV": "production"
  }
}