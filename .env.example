# ============================================================
# UniSync — Environment Configuration Template
# Copy this file to .env and fill in your actual values.
# ============================================================

FLASK_ENV=development
FLASK_SECRET_KEY=change-this-to-a-long-random-string-in-production

# ── Supabase ──────────────────────────────────────────────────
# Find these at: Supabase Dashboard → Project Settings → API

SUPABASE_URL=https://akitkwaeotifdujkoykd.supabase.co

# "anon / public" key (safe to use client-side)
SUPABASE_ANON_KEY=your_anon_key_here

# "service_role" key (KEEP SECRET — bypasses RLS)
SUPABASE_SERVICE_KEY=your_service_role_key_here

# ── App Info ─────────────────────────────────────────────────
APP_NAME=UniSync
UNIVERSITY_NAME=Rabindra University, Bangladesh
DEPARTMENT_NAME=Department of Management
